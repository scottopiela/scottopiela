---
import Header from "@components/Header.astro";
import "@fontsource/be-vietnam-pro";
import "@fontsource-variable/gabarito";
import { SITE_CONFIG } from "@config";
import Footer from "@components/Footer.astro";

const {
  title,
  description,
  siteLogo,
  navLinks,
  lang,
  author,
  socialLinks,
  socialImage,
  canonicalURL = new URL(Astro.url.pathname, Astro.site).href,
} = SITE_CONFIG;

const ogImgUrl = canonicalURL + socialImage;
---

<!doctype html>
<html lang={lang} class="scroll-pt-16 scroll-smooth">
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-V9XK1QW02E"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-V9XK1QW02E');
    </script>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="author" content={author} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/jpeg" href="/scott-small.jpg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImgUrl} />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImgUrl} />

    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content={author} />
    <script is:inline type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Scott Opiela",
      "url": "https://scottopiela.com",
      "email": "scott@opiela.com",
      "jobTitle": "Chief Marketing Officer",
      "description": "PE-backed SaaS growth leader behind $3B+ in exits. 3x CMO specializing in demand generation, revenue operations, and high-performance B2B marketing.",
      "image": "https://scottopiela.com/scott-big.jpg",
      "sameAs": [
        "https://www.linkedin.com/in/scottopiela",
        "https://www.virtualimage.com"
      ],
      "knowsAbout": [
        "B2B SaaS Marketing",
        "Demand Generation",
        "Revenue Operations",
        "PE-backed Growth Marketing",
        "Go-to-Market Strategy",
        "Brand Transformation"
      ],
      "hasOccupation": [
        {
          "@type": "Role",
          "roleName": "Chief Marketing Officer",
          "startDate": "2021",
          "endDate": "2026",
          "worksFor": { "@type": "Organization", "name": "Acoustic", "url": "https://acoustic.com" }
        },
        {
          "@type": "Role",
          "roleName": "Chief Marketing Officer",
          "startDate": "2018",
          "endDate": "2021",
          "worksFor": { "@type": "Organization", "name": "CommerceHub", "url": "https://www.rithum.com" }
        },
        {
          "@type": "Role",
          "roleName": "Chief Marketing Officer",
          "startDate": "2001",
          "endDate": "2017",
          "worksFor": { "@type": "Organization", "name": "Autotask", "url": "https://www.kaseya.com" }
        }
      ]
    }
    </script>
  </head>
  <body class="bg-black font-sans">
    <Header siteLogo={siteLogo} navLinks={navLinks} />
    <main class="mx-auto max-w-3xl px-5">
      <slot />
    </main>
    <Footer author={author} socialLinks={socialLinks} />
  </body>
</html>
