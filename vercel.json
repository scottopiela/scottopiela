{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "scottopiela.vercel.app"
        }
      ],
      "destination": "https://scottopiela.com/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.scottopiela.com"
        }
      ],
      "destination": "https://scottopiela.com/$1",
      "permanent": true
    }
  ]
}